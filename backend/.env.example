# Backend Configuration (Flask API)

# JWT Secret Key - Generate a secure random string for production
# Example: Use Python: import secrets; print(secrets.token_hex(32))
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# CORS Configuration - Allowed origins (comma-separated)
# For development: use * or http://localhost:5173
# For production: use your actual frontend domain
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Database Configuration
# SQLite database file path (relative to backend directory)
DB_PATH=smartcourse.db
